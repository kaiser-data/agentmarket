    "services": "tsx agents/run-services.ts",
    "service": "tsx agents/service.ts",
    "dashboard": "tsx dashboard/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.144",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "openai": "^4.67.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
