{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@agent-stack-ecosystem-kits/circle-tools": ["vendor/circle-tools/src/index.ts"],
      "@agent-stack-ecosystem-kits/kit-core": ["vendor/kit-core/src/index.ts"],
      "@agent-stack-ecosystem-kits/kit-core/*": ["vendor/kit-core/src/*.ts"]
    }
  },
  "include": ["lib", "agents", "scripts", "dashboard", "vendor"]
}
