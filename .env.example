# ---- Circle Agent Stack ----
# Install the Circle CLI globally and authenticate, then install the agent skill:
#   npm i -g @circle-fin/cli   (requires Node 20.18.2+)
#   circle wallet login <email> --type agent --init
#   circle skill install
CIRCLE_CHAIN=BASE
# Agent Wallet address (filled after `circle wallet create` / spike run)
AGENT_WALLET_ADDRESS=

# ---- LLM (Claude Agent SDK kit) ----
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ---- Budget / policy ----
BUDGET_USDC=2.0
APPROVAL_OVER_USDC=1.0

# ---- Simulation ----
# SIMULATE=1 mocks the Circle wallet, marketplace, and payments so the full agent
# loop runs for FREE (no CLI, no login, no USDC). Set to 0 / unset to go live.
SIMULATE=1

# ---- Discovery: Tavily ----
TAVILY_API_KEY=

# ---- Qualify/validate: Nebius Token Factory (OpenAI-compatible) ----
# (Optional — can also use Claude via the kit. Nebius = bonus prize eligibility.)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# DeepSeek-V3.2 drives the tool loop most reliably (tested). Alternatives:
# meta-llama/Llama-3.3-70B-Instruct (works, lazier). Avoid Qwen3 (hallucinated tools).
NEBIUS_MODEL=deepseek-ai/DeepSeek-V3.2

# ---- Local dev services (set LOCAL_SERVICES=1 to use the bundled sellers) ----
LOCAL_SERVICES=1
SVC_A_PORT=4101
SVC_B_PORT=4102
SVC_C_PORT=4103
# payTo addresses for local services (paste Agent Wallet addrs, or leave for demo)
SVC_A_PAYTO=
SVC_B_PAYTO=
SVC_C_PAYTO=
# Override the spike target to hit a real Marketplace service instead of local:
# SPIKE_SERVICE_URL=

# ---- Dashboard ----
DASHBOARD_URL=http://localhost:4000
DASHBOARD_PORT=4000
